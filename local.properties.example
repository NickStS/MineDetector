## This is an example configuration file
# Copy this file to local.properties and fill in your actual values
# DO NOT commit local.properties to version control!

# Android SDK location (auto-generated by Android Studio)
sdk.dir=/path/to/Android/Sdk

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# API KEYS - REQUIRED FOR APP TO WORK
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# DJI Mobile SDK API Key
# Get from: https://developer.dji.com/user/apps/#all
# 1. Create account
# 2. Create new app
# 3. Get App Key
DJI_API_KEY=YOUR_DJI_API_KEY_HERE

# Mapbox Access Token (for mapping features)
# Get from: https://account.mapbox.com/access-tokens/
# Free tier: 50,000 map loads per month
# 1. Sign up for Mapbox account
# 2. Go to Access Tokens
# 3. Copy "Default Public Token" OR create new token
MAPBOX_ACCESS_TOKEN=YOUR_MAPBOX_ACCESS_TOKEN_HERE

# Google Maps API Key (optional, for DJI MapWidget compatibility)
# Get from: https://console.cloud.google.com
# 1. Create project
# 2. Enable "Maps SDK for Android"
# 3. Create credentials (API Key)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_KEY_HERE

# Backend Server URL (for data sync, optional)
# Default is example URL - replace with your actual server
SERVER_URL=https://api.minedetector.example.com/

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# NOTES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# - All keys should be kept secret
# - Never commit local.properties to git
# - This file is already in .gitignore
# - Without valid DJI_API_KEY, app will not connect to drone
# - Without MAPBOX_ACCESS_TOKEN, maps will not load (app will still work but without map display)
