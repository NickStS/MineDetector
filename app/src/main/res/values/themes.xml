<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ============================================ -->
    <!-- MAIN APPLICATION THEME -->
    <!-- ============================================ -->
    <style name="Theme.MineDetector" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>

        <!-- Background Colors -->
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:colorBackground">@color/background_dark</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/background_dark</item>

        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/background_dark</item>

        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Material Components -->
        <item name="materialCardViewStyle">@style/AppCardView</item>
        <item name="buttonStyle">@style/AppButton</item>
    </style>

    <!-- ============================================ -->
    <!-- SPLASH SCREEN THEME -->
    <!-- ============================================ -->
    <style name="Theme.MineDetector.Splash" parent="Theme.MineDetector">
        <!-- Splash screen specific settings -->
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- ============================================ -->
    <!-- FULLSCREEN THEME (for Media Viewer) -->
    <!-- ============================================ -->
    <style name="Theme.MineDetector.Fullscreen" parent="Theme.MineDetector">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- ============================================ -->
    <!-- LEGACY THEME (for compatibility) -->
    <!-- ============================================ -->
    <style name="AppTheme" parent="Theme.MineDetector">
        <!-- Legacy theme redirects to new theme -->
    </style>

    <!-- ============================================ -->
    <!-- FULLSCREEN THEME (for Drone Control) -->
    <!-- ============================================ -->
    <style name="FullscreenTheme" parent="Theme.MineDetector">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- ============================================ -->
    <!-- CARD VIEW STYLE -->
    <!-- ============================================ -->
    <style name="AppCardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">8dp</item>
        <item name="contentPadding">0dp</item>
    </style>

    <!-- ============================================ -->
    <!-- BUTTON STYLE -->
    <!-- ============================================ -->
    <style name="AppButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:paddingStart">32dp</item>
        <item name="android:paddingEnd">32dp</item>
    </style>

    <!-- ============================================ -->
    <!-- TEXT STYLES -->
    <!-- ============================================ -->
    <style name="TextAppearance.Title" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/text_primary</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Subtitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- ============================================ -->
    <!-- CUSTOM STYLES -->
    <!-- ============================================ -->

    <!-- Menu Card Style -->
    <style name="MenuCard" parent="AppCardView">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">12dp</item>
    </style>

    <!-- Large Button Style -->
    <style name="LargeButton" parent="AppButton">
        <item name="android:textSize">18sp</item>
        <item name="android:paddingTop">20dp</item>
        <item name="android:paddingBottom">20dp</item>
    </style>
</resources>