<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dji_background">

    <!-- FULLSCREEN BACKGROUND -->
    <ImageView
        android:id="@+id/iv_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.75"
        android:src="@drawable/bg"
        tools:ignore="ContentDescription" />

    <!-- MAIN CONTENT (NO PADDING HERE!) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- TOP BAR -->
        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_app_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mine Detector"
                android:textColor="@color/dji_white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_about"
                app:tint="@color/dji_white"
                android:contentDescription="About" />

        </LinearLayout>

        <!-- CARDS -->
        <LinearLayout
            android:id="@+id/cards_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/top_bar"
            app:layout_constraintBottom_toTopOf="@id/bottom_section">

            <!-- Album -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_album"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginEnd="12dp"
                app:cardBackgroundColor="@color/dji_card_semi"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_gallery"
                        app:tint="@color/dji_white"
                        tools:ignore="ContentDescription" />

                    <TextView
                        android:layout_marginTop="8dp"
                        android:text="Album"
                        android:textColor="@color/dji_white"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Test -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_test"
                android:layout_width="140dp"
                android:layout_height="140dp"
                app:cardBackgroundColor="@color/dji_card_semi"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_test"
                        app:tint="@color/dji_white"
                        tools:ignore="ContentDescription" />

                    <TextView
                        android:layout_marginTop="8dp"
                        android:text="Test"
                        android:textColor="@color/dji_white"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- RIGHT IMAGE HINT -->
        <ImageView
            android:id="@+id/iv_back_hint"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginEnd="16dp"
            android:alpha="0.2"
            android:scaleType="centerInside"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/top_bar"
            app:layout_constraintBottom_toTopOf="@id/bottom_section"
            tools:ignore="ContentDescription" />

        <!-- BOTTOM SECTION -->
        <LinearLayout
            android:id="@+id/bottom_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_connect_drone"
                android:layout_width="280dp"
                android:layout_height="48dp"
                android:text="CONNECT"
                android:textColor="@color/dji_black"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/dji_white"
                app:cornerRadius="24dp"
                app:elevation="0dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
